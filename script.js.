// Função para mudar o conteúdo da aba de sustentabilidade
function mudarTab(index) {
    // Captura todos os botões e remove a classe 'active'
    const botoes = document.querySelectorAll('.tab-btn');
    botoes.forEach(btn => btn.classList.remove('active'));

    // Adiciona a classe 'active' ao botão clicado
    botoes[index].classList.add('active');

    // Altera o conteúdo interno do container
    const containerConteudo = document.getElementById('tab-content');
    containerConteudo.innerHTML = `
        <h3 style="color: #006437; margin-bottom: 10px;">${dadosSustentabilidade[index].titulo}</h3>
        <p>${dadosSustentabilidade[index].descricao}</p>
    `;
}

// Inicializa a primeira aba assim que a página carrega
window.onload = function() {
    mudarTab(0);
};
